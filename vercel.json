{
  "functions": {
    "api/backend/[...path].js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/auth/(.*)",
      "destination": "/api/backend/auth/$1"
    },
    {
      "source": "/api/admin/(.*)",
      "destination": "/api/backend/admin/$1"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/backend/api/$1"
    },
    {
      "source": "/openapi.yml",
      "destination": "/api/backend/openapi.yml"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
