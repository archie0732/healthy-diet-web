{
  "functions": {
    "api/proxy.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/proxy.js?path=auth/$1"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/proxy.js?path=admin/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/proxy.js?path=api/$1"
    },
    {
      "src": "/openapi.yml",
      "dest": "/api/proxy.js?path=openapi.yml"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
